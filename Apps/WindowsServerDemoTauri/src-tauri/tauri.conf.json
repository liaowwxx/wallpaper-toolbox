{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wallpaper Server",
  "version": "0.1.0",
  "identifier": "com.wallpapergallery.windowsserver",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wallpaper Server",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": {
      "../requirements-tauri.txt": "requirements-tauri.txt",
      "../../WindowsServerDemo/README.md": "WindowsServerDemo/README.md",
      "../../WindowsServerDemo/requirements.txt": "WindowsServerDemo/requirements.txt",
      "../../WindowsServerDemo/wallpaper_server_demo/__init__.py": "WindowsServerDemo/wallpaper_server_demo/__init__.py",
      "../../WindowsServerDemo/wallpaper_server_demo/api.py": "WindowsServerDemo/wallpaper_server_demo/api.py",
      "../../WindowsServerDemo/wallpaper_server_demo/config.py": "WindowsServerDemo/wallpaper_server_demo/config.py",
      "../../WindowsServerDemo/wallpaper_server_demo/library.py": "WindowsServerDemo/wallpaper_server_demo/library.py",
      "../../WindowsServerDemo/wallpaper_server_demo/models.py": "WindowsServerDemo/wallpaper_server_demo/models.py",
      "../../WindowsServerDemo/wallpaper_server_demo/tauri_bridge.py": "WindowsServerDemo/wallpaper_server_demo/tauri_bridge.py"
    }
  }
}
